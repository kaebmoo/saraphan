# ============================================================
# Saraphan (สารพันธ์) — Environment Configuration
# ============================================================
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามความเหมาะสม
# cp .env.example .env
# ============================================================

# === Application ===
APP_NAME=saraphan
APP_ENV=development                     # development | staging | production
APP_PORT=8000
APP_SECRET_KEY=change-this-to-random-string-64-chars
APP_CORS_ORIGINS=http://localhost:3000   # frontend URL

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://saraphan:password@localhost:5432/saraphan
DATABASE_ECHO=false                     # true = log SQL queries

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === RAGFlow ===
RAGFLOW_API_URL=http://localhost:9380
RAGFLOW_API_KEY=

# === Qdrant ===
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                         # ว่างไว้ถ้า dev, ตั้งใน production

# === Embedding ===
# Local embedding (BGE-M3)
EMBEDDING_LOCAL_URL=http://localhost:8080/embed
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# Cloud embedding (Google) — ห้ามใช้ text-embedding-004 มี bug กับภาษาไทย
GOOGLE_EMBEDDING_MODEL=gemini-embedding-001
GOOGLE_API_KEY=

# === LLM Providers ===
# Cloud LLM (สำหรับเอกสาร Level 1-2)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=
DEFAULT_CLOUD_LLM=claude                # claude | openai | gemini

# On-Prem LLM (สำหรับเอกสาร Level 3-4 + PII)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:70b                 # หรือ typhoon-thai

# === OCR ===
# PaddleOCR-VL (ผ่าน RAGFlow DeepDoc)
# ThaiTrOCR fallback
THAITROCR_URL=http://localhost:8081

# === Neo4j (Phase 5 — GraphRAG) ===
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this

# === Auth ===
JWT_SECRET_KEY=change-this-to-another-random-string
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
MAX_CONCURRENT_SESSIONS=3

# NT SSO/LDAP (Phase 3)
# LDAP_URL=ldap://ldap.nt.co.th:389
# LDAP_BASE_DN=dc=nt,dc=co,dc=th
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_AUTHORITY=

# === Cerbos (ACL) ===
CERBOS_URL=http://localhost:3592

# === Langfuse (Observability) ===
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# === Rate Limiting ===
RATE_LIMIT_PER_USER=60                  # queries per hour
RATE_LIMIT_PER_IP=120                   # queries per hour
RATE_LIMIT_BURST=10                     # queries per minute

# === Search Tuning ===
SEARCH_CHUNK_SIZE=512                   # tokens
SEARCH_CHUNK_OVERLAP=64                 # tokens
SEARCH_RRF_K=60
SEARCH_TOP_K_CANDIDATES=30             # ส่ง reranker
SEARCH_FINAL_TOP_K=10                  # ส่ง LLM
SEARCH_QUERY_EXPANSION=true            # เปิด/ปิด query expansion
SEARCH_BLEND_TOP3=0.75                 # position-aware blend: weight RRF สำหรับ rank 1-3
SEARCH_BLEND_MID=0.60                  # weight RRF สำหรับ rank 4-10
SEARCH_BLEND_TAIL=0.40                 # weight RRF สำหรับ rank 11+

# === Audit ===
AUDIT_LOG_RETENTION_YEARS=2            # ตาม PDPA
